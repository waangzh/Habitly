.header { display:flex; align-items:center; justify-content:space-between; padding:calc(20rpx + env(safe-area-inset-top)) 32rpx 20rpx; }
.side { width:132rpx; display:flex; align-items:center; }
.right { justify-content:flex-end; }
.title { flex:1; text-align:center; color:var(--brand-deep); font-size:36rpx; font-weight:600; }
.capsule { min-width:72rpx; height:72rpx; padding:0 22rpx; border-radius:999rpx; background:#fff; box-shadow:var(--soft-shadow); color:var(--brand-deep); display:flex; align-items:center; justify-content:center; font-size:28rpx; font-weight:600; }
.ghost { font-size:24rpx; }
