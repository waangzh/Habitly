.page-scroll { padding-bottom:330rpx; }
.intro { padding:8rpx 32rpx 28rpx; }
.welcome { font-size:48rpx; font-weight:600; color:var(--text-primary); }
.subtitle { margin-top:12rpx; color:var(--text-secondary); font-size:24rpx; }
.summary { margin:24rpx 32rpx; padding:28rpx 0; display:flex; align-items:center; }
.summary-item { flex:1; text-align:center; }
.summary-label { color:var(--text-secondary); font-size:22rpx; }
.summary-value { margin-top:10rpx; font-size:42rpx; font-weight:600; color:var(--brand-deep); }
.success { color:var(--success); }
.divider { width:2rpx; height:64rpx; background:var(--line); }
.list-title { padding:6rpx 32rpx 22rpx; font-size:32rpx; font-weight:600; color:var(--text-primary); }
.brand-footer { text-align:center; padding:24rpx 0 16rpx; }
.brand-pill { display:inline-block; padding:14rpx 32rpx; border-radius:999rpx; background:#dfe9f7; color:var(--text-secondary); }
.brand-text { margin-top:16rpx; color:var(--text-tertiary); }
.floating-actions { position:fixed; left:32rpx; right:32rpx; bottom:156rpx; display:flex; gap:20rpx; z-index:12; }
.action-chip { flex:1; height:84rpx; border-radius:999rpx; background:#ffffff; box-shadow:var(--soft-shadow); display:flex; align-items:center; justify-content:center; color:var(--brand-deep); font-size:28rpx; font-weight:600; }
.action-chip.primary { background:linear-gradient(135deg, #7ab5ff, #5b91ff); color:#fff; }
.sheet-mask { position:fixed; inset:0; background:rgba(28, 41, 62, 0.34); display:flex; align-items:flex-end; z-index:40; }
.sheet-panel { width:100%; background:#fff; border-radius:32rpx 32rpx 0 0; padding:32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom)); }
.sheet-title { text-align:center; font-size:34rpx; font-weight:600; color:var(--text-primary); }
.sheet-subtitle { margin-top:10rpx; text-align:center; color:var(--text-secondary); font-size:24rpx; }
.sheet-section { margin-top:28rpx; }
.sheet-label { color:var(--text-primary); font-size:28rpx; font-weight:600; }
.mood-row { display:flex; gap:16rpx; flex-wrap:wrap; margin-top:18rpx; }
.mood-pill { padding:16rpx 24rpx; border-radius:999rpx; background:#eef5ff; color:var(--text-secondary); }
.mood-pill.active { background:linear-gradient(135deg, #7ab5ff, #5b91ff); color:#fff; }
.sheet-input { margin-top:16rpx; padding:22rpx 24rpx; border-radius:24rpx; background:#f6f9fe; color:var(--text-primary); }
.sheet-actions { display:flex; gap:18rpx; margin-top:34rpx; }
.sheet-btn { flex:1; height:84rpx; line-height:84rpx; text-align:center; border-radius:999rpx; font-weight:600; }
.sheet-btn.ghost { background:#edf3fb; color:var(--text-secondary); }
.sheet-btn.primary { background:linear-gradient(135deg, #7ab5ff, #5b91ff); color:#fff; }
