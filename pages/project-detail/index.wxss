.page-scroll { padding-bottom: 40rpx; }
.hero, .section { margin: 0 32rpx 24rpx; padding: 32rpx; }
.hero-top { display:flex; align-items:center; gap:20rpx; }
.hero-icon { width:92rpx; height:92rpx; border-radius:30rpx; background:#edf5ff; display:flex; align-items:center; justify-content:center; font-size:44rpx; }
.hero-title { font-size:36rpx; font-weight:600; color:var(--text-primary); }
.hero-subtitle { margin-top:10rpx; color:var(--text-secondary); line-height:1.6; }
.hero-stats { display:flex; margin-top:28rpx; gap:16rpx; }
.stat-item { flex:1; padding:22rpx 0; border-radius:24rpx; background:#f7fbff; text-align:center; }
.stat-label { color:var(--text-secondary); font-size:22rpx; }
.stat-value { margin-top:8rpx; color:var(--brand-deep); font-size:36rpx; font-weight:600; }
.action-row { display:flex; gap:20rpx; margin:0 32rpx 24rpx; }
.action-card { flex:1; padding:26rpx 0; text-align:center; color:var(--brand-deep); font-weight:600; }
.section-title { font-size:30rpx; font-weight:600; color:var(--text-primary); margin-bottom:18rpx; }
.info-line { color:var(--text-secondary); margin-top:12rpx; line-height:1.7; }
.reward-item, .record-item { display:flex; justify-content:space-between; align-items:flex-start; gap:20rpx; padding:22rpx 0; border-top:2rpx solid var(--line); }
.reward-item:first-of-type, .record-item:first-of-type { border-top:0; padding-top:8rpx; }
.reward-title, .record-date { color:var(--text-primary); font-weight:600; }
.reward-desc, .record-meta { color:var(--text-secondary); font-size:24rpx; margin-top:8rpx; line-height:1.6; }
.reward-status { min-width:96rpx; padding:12rpx 0; text-align:center; border-radius:999rpx; background:#f5f7fb; color:var(--text-secondary); font-size:22rpx; }
.reward-status.reached { background:#e8f8ef; color:#37a86d; }
.record-extra { color:var(--text-secondary); font-size:24rpx; text-align:right; line-height:1.8; }
