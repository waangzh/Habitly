.page-scroll { padding-bottom:220rpx; }
.hero, .paused-entry { margin:0 32rpx 24rpx; padding:32rpx; }
.hero-title { font-size:38rpx; font-weight:600; color:var(--text-primary); }
.hero-subtitle { margin-top:12rpx; color:var(--text-secondary); line-height:1.7; }
.paused-entry { display:flex; align-items:center; justify-content:space-between; }
.paused-title { font-size:30rpx; font-weight:600; color:var(--text-primary); }
.paused-desc { margin-top:10rpx; color:var(--text-secondary); font-size:24rpx; }
.paused-count { min-width:84rpx; height:84rpx; border-radius:28rpx; background:linear-gradient(135deg, #ffc17b, #ff9f6b); color:#fff; display:flex; align-items:center; justify-content:center; font-size:34rpx; font-weight:600; }
